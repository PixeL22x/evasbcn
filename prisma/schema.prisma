// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Cierre {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajador  String
  turno       String   // "mañana" o "tarde"
  fechaInicio DateTime @default(now())
  fechaFin    DateTime?
  completado  Boolean  @default(false)
  totalVentas Float?   // Total de ventas del día
  ticketData  Json?    // Datos del ticket escaneado con IA (items, imageUrl, etc.)
  tareas      Tarea[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tarea {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre     String
  duracion   Int      // en minutos
  completada Boolean  @default(false)
  subtareas  String?  // Array con las subtareas del bloque (JSON string)
  requiereFotos Boolean @default(false) // Indica si la tarea requiere fotos
  fotosRequeridas String? // Array con los tipos de fotos requeridas (JSON string)
  fotosSubidas String? // URLs de las fotos subidas a Cloudinary (JSON string)
  requiereInput Boolean @default(false) // Indica si la tarea requiere input del usuario
  inputType  String?  // Tipo de input requerido (ej: 'ventas')
  cierreId   String   @db.ObjectId
  cierre     Cierre   @relation(fields: [cierreId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model Trabajador {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre    String   @unique
  password  String
  activo    Boolean  @default(true)
  
  // RRHH Fields (Admin Only)
  email       String?
  telefono    String?
  direccion   String?
  fechaAlta   DateTime? @default(now())
  fechaBaja   DateTime? // Fecha de despido/baja
  cargo       String?   @default("empleado") // "encargado", "empleado"
  dni         String?
  nss         String?  // Seguridad Social
  iban        String?  // Cuenta bancaria
  salarioHora Float?   @default(0)
  notasAdmin  String?  // Bitácora privada
  
  fichajes    RegistroHorario[]
  documentos  Documento[]
  
  pedidos   PedidoHelado[]
  reglasHorario ReglaHorario[]
  excepcionesHorario ExcepcionHorario[]
  movimientosStock MovimientoStock[]
  registrosTemperatura RegistroTemperatura[]
  resenas   Resena[]
  loteTartas LoteTarta[]
  loteMasas  LoteMasa[]
  itemsCompra ItemCompra[]
  tareasAsignadas TareaAsignada[]
  disparosAlarma  DisparoAlarma[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Documento {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId String    @db.ObjectId
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  nombre       String    // "Contrato", "DNI", "Baja Médica"
  url          String    // Cloudinary URL
  tipo         String    // "pdf", "img"
  categoria    String    @default("otros") // "contrato", "nomina", "baja", "identificacion"
  fechaSubida  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PedidoHelado {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId String  @db.ObjectId
  trabajador  Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  sabores     String   // JSON string con los sabores y cantidades
  estado      String   @default("pendiente") // pendiente, procesado, entregado
  observaciones String?
  fechaPedido DateTime @default(now())
  fechaProcesado DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SolicitudCambioTurno {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorSolicitante String   // Nombre del trabajador que solicita
  trabajadorDestino     String   // Nombre del trabajador con quien quiere cambiar
  fechaCambio          DateTime // Fecha que NO puede trabajar
  fechaReemplazo       DateTime? // Fecha que propone trabajar en su lugar (opcional para datos antiguos)
  motivo               String   // Motivo del cambio (obligatorio)
  estado               String   @default("pendiente") // pendiente, aprobada, rechazada
  fechaSolicitud       DateTime @default(now())
  fechaRespuesta       DateTime? // Cuando se aprueba o rechaza
  observacionesAdmin   String?  // Comentarios del administrador
  solicitudComplementaria String? @db.ObjectId // ID de la solicitud del otro trabajador
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

/// Reglas semanales por trabajador (0=Domingo ... 6=Sábado)
model ReglaHorario {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId  String   @db.ObjectId
  trabajador    Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  diaSemana     Int      // 0..6
  turno         String   // "M" (mañana), "T" (tarde) o "L" (libre)
  entrada       String?  // Opcional: hora de entrada (hh:mm)
  salida        String?  // Opcional: hora de salida (hh:mm)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Excepciones puntuales para un día concreto
model ExcepcionHorario {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId  String   @db.ObjectId
  trabajador    Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  fecha         DateTime // Día concreto (se considera solo la fecha)
  turno         String   // "M", "T" o "L"
  entrada       String?  // Opcional: hora de entrada
  salida        String?  // Opcional: hora de salida
  motivo        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Producto {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre      String   @unique
  categoria   String   // "helados", "toppings", "conos", "churros", etc.
  stock       Int      @default(0)
  stockMinimo Int      @default(5) // Alerta cuando llegue aquí
  precio      Float?
  activo      Boolean  @default(true)
  movimientos MovimientoStock[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MovimientoStock {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productoId  String   @db.ObjectId
  producto    Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  tipo        String   // "entrada" o "salida"
  cantidad    Int      // Siempre positivo
  motivo      String   // "compra", "venta", "ajuste", "inventario"
  trabajadorId String? @db.ObjectId
  trabajador  Trabajador? @relation(fields: [trabajadorId], references: [id])
  observaciones String?
  fecha       DateTime @default(now())
  createdAt   DateTime @default(now())
}

model RegistroTemperatura {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId String  @db.ObjectId
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  temperatura  Float   // Temperatura registrada en grados Celsius
  vitrina      String  @default("isa1") // "isa1" o "isa2"
  hora         String  // "14:00", "18:00", "21:00"
  fecha        DateTime // Fecha del registro
  observaciones String? // Notas adicionales del trabajador
  fotoTermometro String? // URL de foto del termómetro (opcional)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Resena {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId String  @db.ObjectId
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  calificacion Int     // 1-5 estrellas
  fechaResena DateTime // Fecha en que se recibió la reseña
  fechaRegistro DateTime @default(now()) // Fecha en que el trabajador la registró
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RegistroHorario {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  trabajadorId  String   @db.ObjectId
  trabajador    Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  fecha         DateTime // The date of the shift (00:00:00)
  entrada       DateTime // Clock in timestamp
  salida        DateTime? // Clock out timestamp
  tipo          String   @default("turno") // "turno", "extra", "descanso"
  validado      Boolean  @default(false)
  observaciones String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Configuracion {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  clave     String   @unique // e.g., "horarios_active_profile"
  valor     Json
  updatedAt DateTime @updatedAt
}

model TicketDiario {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl    String
  fecha       DateTime @default(now())
  total       Float?
  items       Json?    // Array of { name, quantity, price }
  rawResponse String?  // For debugging purposes
  status      String   @default("procesando") // procesando, completado, error, validado
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SaborTarta {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoteTarta {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  sabor             String   // Sabor de la tarta
  fechaEntrada      DateTime // Fecha y hora de entrada en nevera
  fechaLimite       DateTime // Fecha límite (fechaEntrada + 4 días)
  estado            String   @default("activo") // "activo", "finalizado", "merma"
  trabajadorId      String   @db.ObjectId
  trabajador        Trabajador @relation(fields: [trabajadorId], references: [id])
  motivoFinalizacion String? // "finalizado" (plato vacío) o "merma" (día 4)
  fechaFinalizacion DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


model NotaAdmin {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  titulo                String   // Título breve de la nota
  contenido             String   // Contenido detallado
  categoria             String   // "cambio_turno", "horario", "incidencia", "general", "financiero"
  prioridad             String   @default("normal") // "baja", "normal", "alta"
  fecha                 DateTime @default(now()) // Fecha del evento/nota
  trabajadorRelacionado String?  // Nombre del trabajador si aplica
  etiquetas             String?  // JSON array de etiquetas para búsqueda
  archivada             Boolean  @default(false) // Para ocultar notas antiguas
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ============================================
// GESTIÓN DE FACTURAS
// ============================================

model Proveedor {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  nombre          String
  nif             String?
  telefono        String?
  email           String?
  direccion       String?
  categoria       String    // "helados", "ingredientes", "packaging", "servicios", "mantenimiento", "otros"
  
  // Relaciones
  facturas        Factura[]
  
  activo          Boolean   @default(true)
  notas           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Factura {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Identificación
  numero          String
  tipo            String   @default("compra") // "compra", "gasto"
  
  // Proveedor
  proveedorId     String?  @db.ObjectId
  proveedor       Proveedor? @relation(fields: [proveedorId], references: [id])
  proveedorNombre String   // Por si no está en BD
  proveedorNIF    String?
  
  // Categoría
  categoria       String   // "helados", "ingredientes", "packaging", "servicios", "mantenimiento", "otros"
  
  // Importes
  subtotal        Float
  iva             Float
  total           Float
  
  // Fechas
  fecha           DateTime
  fechaVencimiento DateTime?
  
  // Estado de pago
  pagada          Boolean  @default(false)
  fechaPago       DateTime?
  metodoPago      String?  // "efectivo", "tarjeta", "transferencia"
  
  // Archivo
  imagenUrl       String   // URL de Cloudinary
  
  // IA
  escaneadaIA     Boolean  @default(false)
  revisada        Boolean  @default(false)
  
  // Líneas de factura
  lineas          LineaFactura[]
  
  // Metadata
  notas           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LineaFactura {
  id              String  @id @default(auto()) @map("_id") @db.ObjectId
  facturaId       String  @db.ObjectId
  factura         Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  
  concepto        String
  descripcion     String?
  cantidad        Float
  precioUnitario  Float
  total           Float
  
  createdAt       DateTime @default(now())
}

// ============================================
// CONTROL DE MASAS – WAFFLE & CREPS
// ============================================

model TipoMasa {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre    String   @unique // "Waffle", "Creps"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoteMasa {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  numero             Int?       // Número de lote secuencial (para marcar físicamente)
  tipo               String     // "Waffle" o "Creps"
  fechaElaboracion   DateTime   // Fecha/hora de elaboración
  fechaLimite        DateTime   // fechaElaboracion + 3 días
  estado             String     @default("activo") // "activo", "finalizado", "merma"
  trabajadorId       String     @db.ObjectId
  trabajador         Trabajador @relation(fields: [trabajadorId], references: [id])
  motivoFinalizacion String?    // "finalizado" o "merma"
  fechaFinalizacion  DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}


// ============================================
// LISTA DE COMPRAS
// ============================================

model ItemCompra {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  nombre       String
  cantidad     Float?     // número ej. 2
  unidad       String?    // "kg", "L", "unidades", "botes"...
  urgente      Boolean    @default(false)
  estado       String     @default("pendiente") // "pendiente" | "comprado"
  trabajadorId String     @db.ObjectId
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id])
  creadoAt     DateTime   @default(now())
  compradoAt   DateTime?
}

// ─── Tareas Asignadas por el Admin ─────────────────────────────────────────
model TareaAsignada {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  titulo       String
  descripcion  String?
  categoria    String     @default("limpieza")
  // limpieza | mantenimiento | reposicion | higiene | otro
  prioridad    String     @default("normal")
  // baja | normal | alta | urgente
  estado       String     @default("pendiente")
  // pendiente | completada
  trabajadorId String     @db.ObjectId
  trabajador   Trabajador @relation(fields: [trabajadorId], references: [id], onDelete: Cascade)
  creadaPor    String     // Nombre del admin
  fechaLimite  DateTime?
  completadaAt DateTime?
  notasWorker  String?    // Nota del worker al completar
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// ============================================
// STOCK INTELIGENTE DE ENVASES / PACKAGING
// ============================================

model Envase {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  nombre      String         @unique  // "Vaso 400ml", "Tapa plana", "Pajita", "Tarrina pequeña"
  categoria   String         // "vasos", "tapas", "pajitas", "cubiertos", "bolsas", "otros"
  stockActual Int            @default(0)    // unidades actuales en almacén
  stockMinimo Int            @default(50)   // umbral de alerta
  unidad      String         @default("ud") // "ud", "pack", "caja"
  activo      Boolean        @default(true)
  recetas     RecetaEnvase[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// Receta: qué envases consume 1 unidad vendida de un producto del ticket
model RecetaEnvase {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  // Texto que debe aparecer en el nombre del producto del ticket
  productoNombre String   // "smoothie", "milkshake", "bola", "xurro"
  matchType      String   @default("contains") // "contains" | "exact" | "startsWith"
  envaseId       String   @db.ObjectId
  envase         Envase   @relation(fields: [envaseId], references: [id], onDelete: Cascade)
  cantidad       Float    // unidades de envase por 1 unidad vendida del producto
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================
// TIMERS / ALARMAS PROGRAMADAS
// ============================================

model AlarmaTimer {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  titulo       String                           // "Registrar temperatura vitrina"
  descripcion  String?                          // Descripción adicional opcional
  hora         String                           // "21:30" (formato HH:mm)
  recurrencia  String   @default("diaria")      // "diaria" | "unica"
  fechaUnica   DateTime?                        // Solo si recurrencia = "unica"
  activa       Boolean  @default(true)
  sonido       String   @default("beep")        // "beep" | "campana" | "alerta"
  color        String   @default("naranja")     // "rojo" | "naranja" | "azul" | "verde"
  creadaPor    String                           // Nombre del admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  disparos     DisparoAlarma[]
}

// Registro de disparos: evita re-notificar al mismo trabajador el mismo día
model DisparoAlarma {
  id              String      @id @default(auto()) @map("_id") @db.ObjectId
  alarmaId        String      @db.ObjectId
  alarma          AlarmaTimer @relation(fields: [alarmaId], references: [id], onDelete: Cascade)
  trabajadorId    String?     @db.ObjectId
  trabajador      Trabajador? @relation(fields: [trabajadorId], references: [id], onDelete: SetNull)
  trabajadorNombre String
  fecha           DateTime    @default(now())   // Cuándo fue disparada
  descartada      Boolean     @default(false)
  descartadaAt    DateTime?
  createdAt       DateTime    @default(now())
}
